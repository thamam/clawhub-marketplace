{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/env_guard.py\"",
            "timeout": 5000,
            "statusMessage": "Checking for .env modifications"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/env_guard.py\"",
            "timeout": 5000,
            "statusMessage": "Checking for .env modifications"
          }
        ]
      }
    ]
  }
}
